# === Banco de dados (Supabase → Project Settings → Database → Connection string) ===
# App (pooler de transações, porta 6543) — use no DATABASE_URL:
DATABASE_URL="postgresql://postgres.SEU_PROJETO:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrações (conexão direta, porta 5432) — use no DIRECT_URL:
DIRECT_URL="postgresql://postgres.SEU_PROJETO:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Segredo que assina o cookie de sessão — gere um valor longo e aleatório
# (ex: `openssl rand -base64 32`) e NUNCA compartilhe.
AUTH_SECRET="gere-um-segredo-forte-aqui"
